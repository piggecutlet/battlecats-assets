{
  "$schema": "https://www.schemastore.org/prettierrc.json",
  "overrides": [
    {
      "files": ".prettierrc.json5",
      "options": {
        "quoteProps": "preserve",
        "trailingComma": "none"
      }
    },
    {
      "files": "server.json",
      "options": {
        "printWidth": 0
      }
    }
  ]
}
